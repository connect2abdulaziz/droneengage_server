{
    "server_id"                     : "AndruavLap",
    "server_ip"                     : "0.0.0.0",

    // Replace this with your Railway domain for the comm server
    // e.g. "droneengageserver-production.up.railway.app"
    "public_host"                   : "droneengageserver-production.up.railway.app",

    "server_sid"                    : 0,

    // Internal port used in code; Railway will map its own PORT env to this
    "server_port"                   : 9966,

    // We let Railway terminate TLS at the edge, so keep this false
    "enable_SSL"                    : false,

    "dbIP"                          : "localhost",
    "dbuser"                        : "DBUSER",
    "dbpassword"                    : "DBPASSWORD",
    "dbdatabase"                    : "andruav",

    // Live authenticator URL + port
    "s2s_ws_target_ip"              : "meticulous-respect-production.up.railway.app",
    "s2s_ws_target_port"            : "443",

    // These paths are kept for compatibility; they are ignored when enable_SSL=false
    "ssl_key_file"                  : "./ssl/domain.key",
    "ssl_cert_file"                 : "./ssl/domain.crt",

    // In production you should NOT skip TLS verification; keep this false
    "allow_fake_SSL"                : false,
    "ca_cert_path"                  : "./ssl/root.crt",

    "ignoreLoadingTasks"            : true,
    "allow_udpproxy_fixed_port"     : true,

    // logging
    "ignoreLog"                     : true,
    "log_directory"                 : "./logs/",
    "log_timeZone"                  : "GMT",
    "log_detailed"                  : false,

    "ws_compression"                : false,

    // server reboot - reboot server when process memory exceeds a certain limit.
    "memory_max"                    : 973
}